{
  "version": 2,
  "name": "zipic",
  "public": true,
  "builds": [
    {
      "src": "api/index.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.go"
    },
    {
      "src": "/health",
      "dest": "/api/index.go"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/api/index.go"
    },
    {
      "src": "/favicon.svg",
      "dest": "/api/index.go"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.go"
    }
  ]
}